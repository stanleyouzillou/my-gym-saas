generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  members   Member[]
  programs  Program[]
  createdAt DateTime @default(now())
}

model Member {
  id        String   @id @default(cuid())
  tenantId  String
  email     String   @unique
  firstName String
  lastName  String
  clerkUserId String?  @unique
  phone       String?
  status      MemberStatus @default(PENDING)
  activatedAt DateTime?
  bookings  Booking[]
  waitlistEntries WaitlistEntry[]
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Program {
  id         String         @id @default(cuid())
  tenantId   String
  name       String
  sessions   ClassSession[]
  createdAt  DateTime       @default(now())
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
}

model ClassSession {
  id         String    @id @default(cuid())
  programId  String
  startsAt   DateTime
  durationMin Int
  capacity   Int
  coachName  String?
  bookings   Booking[]
  waitlist   WaitlistEntry[]
  program    Program   @relation(fields: [programId], references: [id])
}

model Booking {
  id         String   @id @default(cuid())
  sessionId  String
  memberId   String
  status     BookingStatus @default(BOOKED)
  createdAt  DateTime @default(now())
  session    ClassSession @relation(fields: [sessionId], references: [id])
  member     Member       @relation(fields: [memberId], references: [id])
}

enum BookingStatus {
  BOOKED
  CANCELLED
  WAITLISTED
}

model WaitlistEntry {
  id         String   @id @default(cuid())
  sessionId  String
  memberId   String
  createdAt  DateTime @default(now())
  session    ClassSession @relation(fields: [sessionId], references: [id])
  member     Member       @relation(fields: [memberId], references: [id])
}

enum MemberStatus {
  PENDING
  ACTIVE
}
